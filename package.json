{
  "name": "cc-plugin-codex-workspace",
  "private": true,
  "version": "0.3.0",
  "description": "Codex plugin: delegate coding tasks to Claude Code, then review results.",
  "scripts": {
    "test": "node --test \"plugins/cc-plugin-codex/tests/*.test.mjs\"",
    "test:verbose": "node --test --test-reporter spec \"plugins/cc-plugin-codex/tests/*.test.mjs\"",
    "verify": "node scripts/verify-install.mjs",
    "verify:source": "node scripts/verify-install.mjs --source-only",
    "verify:ci": "node scripts/verify-install.mjs --ci"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
